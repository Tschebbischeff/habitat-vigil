# This file contains environment variables for the build-context.
# It is also passed into every single docker container.
# Use files in .env.d to overwrite environment variables or pass variables into individual docker containers only.
APP_HOST="${APP_HOST}"
APP_MODULES="${APP_MODULES}"
APP_SESSION_ID="${APP_SESSION_ID}"
APP_NAME_HOST="${APP_NAME_HOST:-habitat}"
APP_NAME_LABEL="${APP_NAME_LABEL:-Habitat}"
TIMEZONE="${TIMEZONE:-Europe/Berlin}"
VOLUME_DIR="${VOLUME_DIR:-./.volumes}"
ENV_DIR="${ENV_DIR:-./.env.d}"
SECRETS_DIR="${SECRETS_DIR:-/.secrets}"
